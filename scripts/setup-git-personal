#!/usr/bin/env bash
set -euo pipefail

. "$HOME/home/shrecipes/identity.shrc"

if [[ ! -f "$PERSONAL_SSH_KEY" ]]
then
    echo "No personal SSH key found at $PERSONAL_SSH_KEY — run bootstrap first." >&2
    exit 1
fi

FINGERPRINT=$(getGpgFingerprint "$PERSONAL_EMAIL")
if [[ -z "$FINGERPRINT" ]]
then
    echo "No personal GPG key found for $PERSONAL_EMAIL — run bootstrap first." >&2
    exit 1
fi

echo "Setting global git identity to personal..."
git config --global user.name "$PERSONAL_NAME"
git config --global user.email "$PERSONAL_EMAIL"
git config --global user.signingkey "$FINGERPRINT"
git config --global commit.gpgsign true
echo "Git config set."

echo "Configuring SSH for github.com..."
ensureSshConfig
addSshBlock "github.com" "    HostName github.com
    User git
    IdentityFile $PERSONAL_SSH_KEY
    IdentitiesOnly yes"

cat <<EOF

Add your personal SSH public key to GitHub:
EOF
cat "$PERSONAL_SSH_KEY.pub"

cat <<EOF

Add your personal GPG key to GitHub:
EOF
gpg --armor --export "$FINGERPRINT"
