#!/usr/bin/env bash
set -euo pipefail

if ! command -v asdf &>/dev/null
then
    cat >&2 <<'EOF'
asdf is not installed.

  https://github.com/asdf-vm/asdf/releases

Once you have a tarball URL, run:
  install-asdf <url-to-.tar.gz>
EOF
    exit 1
fi

echo "asdf found: $(asdf version) at $(command -v asdf)"

. "$HOME/home/conf/asdf.env"

if asdf plugin list 2>/dev/null | grep -q asdf-plugin-manager
then
    echo "asdf-plugin-manager plugin already installed"
else
    echo "asdf-plugin-manager plugin not found, installing..."
    asdf plugin add asdf-plugin-manager https://github.com/asdf-community/asdf-plugin-manager.git
    asdf plugin update asdf-plugin-manager v1.5.0
fi

if asdf list asdf-plugin-manager | grep -s "$ASDF_PLUGIN_MANAGER_VERSION" &>/dev/null
then
    echo "asdf-plugin-manager $ASDF_PLUGIN_MANAGER_VERSION already installed"
else
    echo "Installing asdf-plugin-manager $ASDF_PLUGIN_MANAGER_VERSION..."
    asdf install asdf-plugin-manager "$ASDF_PLUGIN_MANAGER_VERSION"
fi

if asdf current asdf-plugin-manager &>/dev/null
then
    echo "asdf-plugin-manager version already set, leaving alone"
else
    echo "Setting global asdf-plugin-manager to $ASDF_PLUGIN_MANAGER_VERSION"
    asdf set -u asdf-plugin-manager "$ASDF_PLUGIN_MANAGER_VERSION"
fi

echo "Running asdf-plugin-manager add-all..."
asdf-plugin-manager add-all
